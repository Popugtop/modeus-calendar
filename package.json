{
  "name": "modeus-bot",
  "version": "1.0.0",
  "description": "Modeus (utmn.ru) API client with SSO authentication",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:server": "node dist/server.js",
    "dev": "npx ts-node src/index.ts",
    "dev:server": "npx ts-node src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "axios-cookiejar-support": "^5.0.0",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "ical-generator": "^10.0.0",
    "node-cron": "^4.2.1",
    "tough-cookie": "^5.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.7",
    "@types/node-cron": "^3.0.11",
    "@types/tough-cookie": "^4.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}

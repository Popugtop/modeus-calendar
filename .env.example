# Логин от аккаунта utmn.modeus.org
MODEUS_USERNAME=ivanov.ii@s.utmn.ru

# Пароль
MODEUS_PASSWORD=your_password

# Порт Express-сервера (по умолчанию 3000)
PORT=3000

# Путь к SQLite-базе данных
DB_PATH=./calendar.db

# Cron-расписание синхронизации (по умолчанию каждые 3 часа)
CRON_SCHEDULE=0 */3 * * *

# Сколько недель вперёд загружать расписание
SYNC_WEEKS_AHEAD=4

# ── Invite system ─────────────────────────────────────────────────────────────
# Set to false to disable invite code requirement (for development)
INVITE_REQUIRED=true

# Internal secret for bot-to-backend communication (generate a strong random string)
INTERNAL_SECRET=change-me-to-a-random-string

# ── Telegram bot ──────────────────────────────────────────────────────────────
# Get token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFghijklmnopqrstuvwxyz

# Your Telegram user ID (use @userinfobot to get it)
TELEGRAM_ADMIN_ID=123456789

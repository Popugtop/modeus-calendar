# Логин от аккаунта utmn.modeus.org
MODEUS_USERNAME=ivanov.ii@s.utmn.ru

# Пароль
MODEUS_PASSWORD=your_password

# Порт Express-сервера (по умолчанию 3000)
PORT=3000

# Путь к SQLite-базе данных
DB_PATH=./calendar.db

# Cron-расписание синхронизации (по умолчанию каждые 3 часа)
CRON_SCHEDULE=0 */3 * * *

# Сколько недель вперёд загружать расписание
SYNC_WEEKS_AHEAD=4
